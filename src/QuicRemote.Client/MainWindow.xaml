<Window x:Class="QuicRemote.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuicRemote.Client.ViewModels"
        xmlns:controls="clr-namespace:QuicRemote.Client.Controls"
        xmlns:local="clr-namespace:QuicRemote.Client"
        Style="{StaticResource AppleWindow}"
        Title="QuicRemote"
        Height="600" Width="480"
        MinHeight="600" MinWidth="480"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:ConnectViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
    </Window.Resources>

    <!-- Main Container -->
    <Border CornerRadius="12" Background="#F5F5F7" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.15"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Padding="20,16" MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid>
                    <TextBlock Text="QuicRemote"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#1D1D1F"
                               HorizontalAlignment="Center"/>

                    <!-- Settings Button -->
                    <Button Style="{StaticResource IconButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ToolTip="Settings">
                        <Path Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"
                              Fill="#86868B"
                              Width="20" Height="20"
                              Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Connect View -->
            <StackPanel Grid.Row="1" Margin="24,0" Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">

                <!-- Logo/Icon -->
                <Border Width="100" Height="100"
                        Background="#0071E3"
                        CornerRadius="24"
                        Margin="0,20,0,32"
                        HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25"/>
                    </Border.Effect>
                    <Path Data="M21,3H3C1.9,3,1,3.9,1,5v14c0,1.1,0.9,2,2,2h18c1.1,0,2-0.9,2-2V5C23,3.9,22.1,3,21,3z M21,19H3V5h18V19z M9,8h2v8H9V8z M13,12h2v4h-2V12z M17,10h2v6h-2V10z M5,12h2v4H5V12z"
                          Fill="White"
                          Width="48" Height="48"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>

                <!-- Device ID Input -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Device ID"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,8"/>

                        <TextBox Text="{Binding DeviceId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}"
                                 FontSize="28"
                                 FontWeight="Bold"
                                 TextAlignment="Center"
                                 CharacterCasing="Upper"
                                 MaxLength="6"
                                 Height="56"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Or Divider -->
                <Grid Margin="0,8,0,24">
                    <Border Height="1" Background="#E5E5EA" VerticalAlignment="Center"/>
                    <Border Background="#F5F5F7" Padding="16,0" HorizontalAlignment="Center">
                        <TextBlock Text="or"
                                   Style="{StaticResource CaptionText}"
                                   FontSize="14"/>
                    </Border>
                </Grid>

                <!-- Host Input -->
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="Host Address"
                               Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center"/>
                </Grid>

                <Border Style="{StaticResource Card}" Margin="0,0,0,16" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}"
                                 Padding="0"
                                 VerticalContentAlignment="Center"
                                 Height="40"
                                 BorderThickness="0"/>

                        <TextBlock Grid.Column="1"
                                   Text=":"
                                   FontSize="18"
                                   Foreground="#86868B"
                                   Margin="8,0"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Column="2"
                                 Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}"
                                 Padding="0"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Height="40"
                                 BorderThickness="0"/>
                    </Grid>
                </Border>

                <!-- Status -->
                <Grid Margin="0,0,0,24" Height="32">
                    <Border Background="{Binding StatusColor, Converter={StaticResource ColorToBrushConverter}}"
                            CornerRadius="8"
                            Padding="16,6"
                            HorizontalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="White"/>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Remote View (Connected) -->
            <Grid Grid.Row="1" Margin="0" Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Remote Display -->
                <Border Background="#1D1D1F" CornerRadius="8" Margin="16,8">
                    <Grid>
                        <!-- Stats Overlay -->
                        <Border Background="#80000000"
                                CornerRadius="6"
                                Padding="12,6"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding FramesPerSecond, StringFormat={}{0} fps}"
                                           FontSize="12"
                                           Foreground="White"
                                           Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding Latency, StringFormat={}{0:F0} ms}"
                                           FontSize="12"
                                           Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom Actions -->
            <Border Grid.Row="2" Padding="24,20" Background="Transparent">
                <Grid>
                    <!-- Connect Button -->
                    <Button Command="{Binding ConnectCommand}"
                            Height="50"
                            FontSize="16"
                            Content="Connect"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                        <Setter Property="Content" Value="Connecting..."/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Disconnect Button -->
                    <Button Command="{Binding DisconnectCommand}"
                            Height="50"
                            FontSize="16"
                            Content="Disconnect"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Background" Value="#FF3B30"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
