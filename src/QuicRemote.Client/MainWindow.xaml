<Window x:Class="QuicRemote.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuicRemote Client" Height="500" Width="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="12" Background="White" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="QuicRemote Client"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="输入设备码或IP地址连接"
                               FontSize="14"
                               Foreground="Gray"
                               HorizontalAlignment="Center"/>
                    <TextBox Width="250" Margin="0,10,0,0" Padding="8"/>
                    <Button Content="连接" Margin="0,10,0,0" Padding="20,8"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
